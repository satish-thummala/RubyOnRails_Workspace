<div class="container">
  <div class="card">
    <h1>Create account</h1>
    <p class="subtitle">Join us today — it's free</p>

    <% if @user.errors.any? %>
      <div class="errors">
        <ul>
          <% @user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @user, url: signup_path, local: true do |f| %>
      <div class="form-group">
        <%= f.label :name, "Full name" %>
        <%= f.text_field :name, placeholder: "Jane Doe", value: @user.name, autocomplete: "name" %>
      </div>

      <div class="form-group">
        <%= f.label :email, "Email address" %>
        <%= f.email_field :email, placeholder: "you@example.com", value: @user.email, autocomplete: "email" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "Password" %>
        <%= f.password_field :password, placeholder: "Min. 6 characters", autocomplete: "new-password" %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, "Confirm password" %>
        <%= f.password_field :password_confirmation, placeholder: "Repeat password", autocomplete: "new-password" %>
      </div>

      <%= f.submit "Create Account", class: "btn" %>
    <% end %>

    <div class="link-text">
      Already have an account? <a href="<%= login_path %>">Sign in</a>
    </div>
  </div>
</div>
