<div class="container">
  <div class="card">
    <h1>Welcome back</h1>
    <p class="subtitle">Sign in to your account</p>

    <%= form_with url: login_path, local: true, id: "login-form" do |f| %>
      <div class="form-group">
        <%= f.label :email, "Email address" %>
        <%= f.email_field :email, placeholder: "you@example.com", autocomplete: "email", id: "email-field" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "Password" %>
        <%= f.password_field :password, placeholder: "••••••••", autocomplete: "current-password", id: "password-field" %>
      </div>

      <%= f.submit "Sign In", class: "btn" %>
    <% end %>

    <div style="margin-top: 1.5rem; background: #f8f9ff; border: 1px solid #e0e4ff; border-radius: 10px; padding: 1rem;">
      <p style="font-size: 0.8rem; font-weight: 600; color: #6b7280; margin-bottom: 0.6rem;">Demo accounts (click to fill):</p>
      <div style="font-size: 0.875rem;">
        <span style="color: #6b7280;">Demo: </span>
        <a href="#" onclick="fillDemo('demo@example.com', 'password123'); return false;"
           style="color: #667eea; font-weight: 600; text-decoration: none;">
          demo@example.com
        </a>
        <span style="color: #9ca3af;"> / </span>
        <a href="#" onclick="fillDemo('demo@example.com', 'password123'); return false;"
           style="color: #667eea; font-weight: 600; text-decoration: none;">
          password123
        </a>
      </div>
    </div>

    <div class="link-text">
      Don't have an account? <a href="<%= signup_path %>">Create one</a>
    </div>
  </div>
</div>

<script>
  function fillDemo(email, password) {
    document.getElementById('email-field').value = email;
    document.getElementById('password-field').value = password;
  }
</script>
